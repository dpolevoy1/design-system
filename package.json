{
  "name": "@assemble/design-system",
  "version": "0.1.0",
  "description": "Design tokens and React UI primitives for A.Team Assemble",
  "type": "module",
  "sideEffects": [
    "**/*.module.css",
    "**/*.css"
  ],
  "exports": {
    "./tokens/color-palette.css": "./tokens/color-palette.css",
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tooltip": {
      "types": "./src/Tooltip/index.ts",
      "default": "./src/Tooltip/index.ts"
    },
    "./toggle-indicator": {
      "types": "./src/ToggleIndicator/index.ts",
      "default": "./src/ToggleIndicator/index.ts"
    },
    "./spinner": {
      "types": "./src/Spinner/index.ts",
      "default": "./src/Spinner/index.ts"
    }
  },
  "files": [
    "tokens",
    "src",
    "docs",
    "README.md"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "~5.6.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpolevoy1/design-system.git"
  },
  "license": "UNLICENSED"
}
